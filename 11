<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Step 4 Inventory</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #faf9f7;
    --surface: #ffffff;
    --surface2: #f3f2ef;
    --border: rgba(0,0,0,0.12);
    --border2: rgba(0,0,0,0.22);
    --text: #1a1a18;
    --text2: #5a5a56;
    --text3: #9a9994;
    --radius: 12px;
    --radius-sm: 8px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #141412;
      --surface: #1e1e1b;
      --surface2: #282825;
      --border: rgba(255,255,255,0.1);
      --border2: rgba(255,255,255,0.2);
      --text: #f0ede8;
      --text2: #9a9892;
      --text3: #5e5d59;
    }
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 0;
  }

  .header {
    background: var(--surface);
    border-bottom: 0.5px solid var(--border);
    padding: 1rem 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-top {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 0.75rem;
  }

  .app-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .app-sub {
    font-size: 13px;
    color: var(--text3);
  }

  .nav {
    display: flex;
    gap: 0;
  }

  .nav button {
    flex: 1;
    background: none;
    border: none;
    padding: 10px 0;
    font-size: 14px;
    color: var(--text2);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
    font-family: inherit;
  }

  .nav button.active {
    color: var(--text);
    font-weight: 500;
    border-bottom-color: var(--text);
  }

  .content {
    max-width: 600px;
    margin: 0 auto;
    padding: 1.25rem 1rem 4rem;
  }

  .section { display: none; }
  .section.active { display: block; }

  .page-sub {
    font-size: 14px;
    color: var(--text2);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .type-selector {
    display: flex;
    gap: 8px;
    margin-bottom: 1.25rem;
  }

  .type-btn {
    flex: 1;
    padding: 9px 4px;
    text-align: center;
    border: 0.5px solid var(--border2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 13px;
    color: var(--text2);
    background: var(--surface);
    transition: all 0.12s;
    font-family: inherit;
  }

  .type-btn.active {
    border: 2px solid var(--text);
    color: var(--text);
    font-weight: 500;
    background: var(--surface);
  }

  .card {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .form-group { margin-bottom: 1rem; }

  .form-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 6px;
    display: block;
  }

  .form-input {
    width: 100%;
    padding: 10px 12px;
    font-size: 15px;
